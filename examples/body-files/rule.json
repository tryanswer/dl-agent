{
  "spId": "<spId>",
  "title": "cleared merchant net amount settles consistently",
  "modelId": "<riskModelCode>",
  "modelVersion": "<riskModelVersion>",
  "ruleType": "LOGIC",
  "ruleContent": "driftledger.clearing_record#net_amount = driftledger.settlement_record#settlement_amount WHERE driftledger.clearing_record#clearing_status = 'CLEARED'",
  "state": "ONLINE",
  "generateType": "CUSTOM",
  "ruleTables": ["driftledger.clearing_record", "driftledger.settlement_record"]
}
