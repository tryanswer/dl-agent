{
  "name": "dl-agent",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "dl-agent",
      "version": "0.1.0",
      "license": "Apache-2.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@driftledger/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "packages/cli": {
      "name": "@driftledger/cli",
      "version": "0.1.0",
      "license": "Apache-2.0",
      "bin": {
        "dl": "bin/driftledger.js",
        "driftledger": "bin/driftledger.js"
      },
      "engines": {
        "node": ">=20"
      }
    }
  }
}
